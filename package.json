{
  "name": "greenie-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "npx -y kill-port 4000 4200",
    "start": "concurrently \"cd backend && node index.js\" \"ng serve --open\"",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/common": "^18.0.0",
    "@angular/compiler": "^18.0.0",
    "@angular/core": "^18.0.0",
    "@angular/forms": "^18.0.0",
    "@angular/platform-browser": "^18.0.0",
    "@angular/router": "^18.0.0",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.8.3",
    "zone.js": "^0.14.10"
  },
  "devDependencies": {
    "@angular/build": "^18.0.0",
    "@angular/cli": "^18.0.0",
    "@angular/compiler-cli": "^18.0.0",
    "concurrently": "^9.2.1",
    "jsdom": "^27.1.0",
    "pm2": "^6.0.14",
    "tslib": "^2.8.1",
    "typescript": "~5.4.0",
    "vitest": "^4.0.8"
  }
}
